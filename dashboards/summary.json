{
  "dashboard": {
    "uid": "alloy-drilldown",
    "title": "Server Drill-Down (Alloy)",
    "tags": ["server", "drilldown", "alloy"],
    "refresh": "30s",
    "time": {"from": "now-6h", "to": "now"},
    "templating": {"list": [{"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "includeAll": false, "label": "Host", "name": "host", "query": {"query": "label_values(node_uname_info{job=\"integrations/unix\"}, host)", "refId": "StandardVariableQuery"}, "refresh": 2, "sort": 1, "type": "query"}]},
    "panels": [
      {
        "gridPos": {"h": 2, "w": 24, "x": 0, "y": 0}, "id": 100,
        "options": {"content": "<div style=\"display:flex;align-items:flex-end;gap:24px;padding:8px 18px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-family:Inter,system-ui,sans-serif;font-size:14px;\"><a style=\"color:#fff;text-decoration:none;padding:6px 2px 8px;border-bottom:2px solid #f59e0b;font-weight:600;\">Summary</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-proc/server-drill-down-processes-alloy?var-host=${host}&${__url_time_range}\">Processes</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-port/server-drill-down-ports-alloy?var-host=${host}&${__url_time_range}\">Ports</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-cpu/server-drill-down-cpu-alloy?var-host=${host}&${__url_time_range}\">CPU</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-mem/server-drill-down-memory-alloy?var-host=${host}&${__url_time_range}\">Memory</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-disk/server-drill-down-disks-alloy?var-host=${host}&${__url_time_range}\">Disks</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-dd-net/server-drill-down-network-alloy?var-host=${host}&${__url_time_range}\">Network</a></div>", "mode": "html"},
        "title": "", "transparent": true, "type": "text"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"decimals": 2, "max": 100, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 95}, {"color": "green", "value": 99}]}, "unit": "percent"}},
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 2}, "id": 2,
        "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "max(avg_over_time(up{job=\"integrations/unix\",host=\"$host\"}[$__range])) * 100", "refId": "A"}],
        "title": "Availability", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}},
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 2}, "id": 3,
        "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode=\"idle\"}[5m])) * 100)", "refId": "A"}],
        "title": "CPU", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}},
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 2}, "id": 4,
        "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes{host=\"$host\",job=\"integrations/unix\"} / node_memory_MemTotal_bytes{host=\"$host\",job=\"integrations/unix\"})) * 100", "refId": "A"}],
        "title": "Memory", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}},
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 2}, "id": 5,
        "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "100 - ((node_filesystem_avail_bytes{host=\"$host\",job=\"integrations/unix\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{host=\"$host\",job=\"integrations/unix\",mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)", "refId": "A"}],
        "title": "Disk /", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "short"}},
        "gridPos": {"h": 4, "w": 3, "x": 16, "y": 2}, "id": 23,
        "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "count(probe_success{host=\"$host\"} == 1) or on() vector(0)", "refId": "A"}],
        "title": "Ports Up", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}},
        "gridPos": {"h": 4, "w": 3, "x": 19, "y": 2}, "id": 24,
        "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "count(probe_success{host=\"$host\"} == 0) or on() vector(0)", "refId": "A"}],
        "title": "Ports Down", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"decimals": 2, "max": 100, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 99}, {"color": "green", "value": 99.9}]}, "unit": "percent"}},
        "gridPos": {"h": 4, "w": 2, "x": 22, "y": 2}, "id": 7,
        "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"},
        "targets": [{"expr": "max(avg_over_time(up{job=\"integrations/unix\",host=\"$host\"}[$__range])) * 100", "refId": "A"}],
        "title": "SLA", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "description": "System uptime, CPU cores, RAM, load",
        "fieldConfig": {"defaults": {"color": {"fixedColor": "text", "mode": "fixed"}}, "overrides": [{"matcher": {"id": "byName", "options": "Uptime"}, "properties": [{"id": "unit", "value": "s"}]}, {"matcher": {"id": "byName", "options": "RAM"}, "properties": [{"id": "unit", "value": "bytes"}]}]},
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 6}, "id": 31,
        "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "values": true}, "textMode": "value_and_name"},
        "targets": [
          {"expr": "time() - node_boot_time_seconds{host=\"$host\",job=\"integrations/unix\"}", "legendFormat": "Uptime", "refId": "A"},
          {"expr": "count(count by (cpu) (node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode=\"idle\"}))", "legendFormat": "CPU Cores", "refId": "B"},
          {"expr": "node_memory_MemTotal_bytes{host=\"$host\",job=\"integrations/unix\"}", "legendFormat": "RAM", "refId": "C"},
          {"expr": "node_load1{host=\"$host\",job=\"integrations/unix\"}", "legendFormat": "Load 1m", "refId": "D"},
          {"expr": "count(node_filesystem_size_bytes{host=\"$host\",job=\"integrations/unix\",fstype!~\"tmpfs|overlay|nsfs|squashfs\"})", "legendFormat": "Mounts", "refId": "E"}
        ],
        "title": "System Info", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "description": "Up/Down state of all probed ports",
        "fieldConfig": {"defaults": {"custom": {"fillOpacity": 85, "lineWidth": 0}, "mappings": [{"options": {"0": {"color": "red", "index": 0, "text": "Down"}, "1": {"color": "green", "index": 1, "text": "Up"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 10}, "id": 10,
        "options": {"alignValue": "left", "legend": {"displayMode": "list", "placement": "bottom"}, "mergeValues": true, "rowHeight": 0.85, "showValue": "never"},
        "targets": [{"expr": "probe_success{host=\"$host\"}", "legendFormat": "{{job}}", "refId": "A"}],
        "title": "Port Status Timeline", "type": "state-timeline"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}, "1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
        "gridPos": {"h": 5, "w": 12, "x": 0, "y": 16}, "id": 40,
        "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": true}, "textMode": "value_and_name"},
        "targets": [{"expr": "probe_success{host=\"$host\"}", "legendFormat": "{{job}}", "refId": "A"}],
        "title": "Monitored Ports", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "unit": "short"}},
        "gridPos": {"h": 5, "w": 12, "x": 12, "y": 16}, "id": 41,
        "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": true}, "textMode": "value_and_name"},
        "targets": [{"expr": "namedprocess_namegroup_num_procs{host=\"$host\"}", "legendFormat": "{{groupname}}", "refId": "A"}],
        "title": "Monitored Processes", "type": "stat"
      },
      {
        "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
        "fieldConfig": {"defaults": {"custom": {"align": "left"}}},
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 21}, "id": 30,
        "options": {"frameIndex": 0, "showHeader": true},
        "targets": [{"expr": "node_uname_info{host=\"$host\",job=\"integrations/unix\"}", "format": "table", "instant": true, "refId": "A"}],
        "title": "Server Details",
        "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "domainname": true, "job": true, "version": true, "env": true, "host": true, "instance": true}, "renameByName": {"machine": "Arch", "nodename": "Hostname", "release": "Kernel", "sysname": "OS"}}}],
        "type": "table"
      }
    ]
  },
  "folderUid": "monitoring",
  "overwrite": true
}

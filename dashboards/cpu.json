    "panels": [
      {"gridPos": {"h": 3, "w": 24, "x": 0, "y": 0}, "id": 100, "options": {"content": "<div style=\"display:flex;align-items:flex-end;gap:24px;padding:12px 18px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-family:Inter,system-ui,sans-serif;font-size:14px;\"><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-drilldown/server-drill-down-alloy?var-host=${host}&${__url_time_range}\">Summary</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-proc/server-drill-down-processes-alloy?var-host=${host}&${__url_time_range}\">Processes</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-port/server-drill-down-ports-alloy?var-host=${host}&${__url_time_range}\">Ports</a><a style=\"color:#fff;text-decoration:none;padding:6px 2px 10px;border-bottom:2px solid #f59e0b;font-weight:600;\">CPU</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-mem/server-drill-down-memory-alloy?var-host=${host}&${__url_time_range}\">Memory</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-disk/server-drill-down-disks-alloy?var-host=${host}&${__url_time_range}\">Disks</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-net/server-drill-down-network-alloy?var-host=${host}&${__url_time_range}\">Network</a></div>", "mode": "html"}, "title": "", "transparent": true, "type": "text"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"decimals": 1, "max": 100, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}}, "gridPos": {"h": 5, "w": 6, "x": 0, "y": 3}, "id": 1, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode=\"idle\"}[5m])) * 100)", "refId": "A"}], "title": "CPU Usage", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 5, "w": 6, "x": 6, "y": 3}, "id": 2, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "avg(node_load1{host=\"$host\",job=\"integrations/unix\"})", "refId": "A"}], "title": "Load 1m", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 5, "w": 6, "x": 12, "y": 3}, "id": 3, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(count by (cpu) (node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode=\"idle\"}))", "refId": "A"}], "title": "Cores", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "unit": "ops"}}, "gridPos": {"h": 5, "w": 6, "x": 18, "y": 3}, "id": 4, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "avg(rate(node_context_switches_total{host=\"$host\",job=\"integrations/unix\"}[5m]))", "refId": "A"}], "title": "Ctx Switches /s", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 30, "lineWidth": 1, "stacking": {"mode": "normal"}}, "unit": "percent"}}, "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8}, "id": 5, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode!=\"idle\"}[5m])) * 100", "legendFormat": "{{mode}}", "refId": "A"}], "title": "CPU Usage by Mode (stacked)", "type": "timeseries"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 10, "lineWidth": 1}, "unit": "percent"}}, "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8}, "id": 6, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "100 - (rate(node_cpu_seconds_total{host=\"$host\",job=\"integrations/unix\",mode=\"idle\"}[5m]) * 100)", "legendFormat": "cpu{{cpu}}", "refId": "A"}], "title": "Per-Core CPU Busy", "type": "timeseries"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17}, "id": 7, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "avg(node_load1{host=\"$host\",job=\"integrations/unix\"})", "legendFormat": "1m", "refId": "A"}, {"expr": "avg(node_load5{host=\"$host\",job=\"integrations/unix\"})", "legendFormat": "5m", "refId": "B"}, {"expr": "avg(node_load15{host=\"$host\",job=\"integrations/unix\"})", "legendFormat": "15m", "refId": "C"}], "title": "Load Average", "type": "timeseries"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "ops"}}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17}, "id": 8, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "avg(rate(node_intr_total{host=\"$host\",job=\"integrations/unix\"}[5m]))", "legendFormat": "interrupts", "refId": "A"}, {"expr": "avg(rate(node_forks_total{host=\"$host\",job=\"integrations/unix\"}[5m]))", "legendFormat": "forks", "refId": "B"}, {"expr": "avg(rate(node_context_switches_total{host=\"$host\",job=\"integrations/unix\"}[5m]))", "legendFormat": "ctx switches", "refId": "C"}], "title": "Interrupts / Forks / Ctx Switches", "type": "timeseries"}
    ]

{
  "dashboard": {
    "uid": "alloy-dd-port",
    "title": "Server Drill-Down · Ports (Alloy)",
    "tags": ["ports", "drilldown", "server", "alloy"],
    "refresh": "30s",
    "time": {"from": "now-1h", "to": "now"},
    "templating": {
      "list": [
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "includeAll": false,
          "label": "Host",
          "name": "host",
          "query": {"query": "label_values(node_uname_info{job=\"integrations/unix\"}, host)", "refId": "StandardVariableQuery"},
          "refresh": 2,
          "sort": 1,
          "type": "query"
        },
        {
          "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
          "includeAll": true,
          "allValue": ".*",
          "multi": true,
          "label": "Port / Endpoint",
          "name": "port",
          "query": {"query": "label_values(probe_success{host=\"$host\"}, job)", "refId": "StandardVariableQuery"},
          "refresh": 2,
          "sort": 1,
          "type": "query",
          "current": {"text": "All", "value": "$__all"}
        }
      ]
    },
    "panels": [
      {"gridPos": {"h": 3, "w": 24, "x": 0, "y": 0}, "id": 100, "options": {"content": "<div style=\"display:flex;align-items:flex-end;gap:24px;padding:12px 18px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-family:Inter,system-ui,sans-serif;font-size:14px;\"><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-drilldown/server-drill-down-alloy?var-host=${host}&${__url_time_range}\">Summary</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-proc/server-drill-down-processes-alloy?var-host=${host}&${__url_time_range}\">Processes</a><a style=\"color:#fff;text-decoration:none;padding:6px 2px 10px;border-bottom:2px solid #f59e0b;font-weight:600;\">Ports</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-cpu/server-drill-down-cpu-alloy?var-host=${host}&${__url_time_range}\">CPU</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-mem/server-drill-down-memory-alloy?var-host=${host}&${__url_time_range}\">Memory</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-disk/server-drill-down-disks-alloy?var-host=${host}&${__url_time_range}\">Disks</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-net/server-drill-down-network-alloy?var-host=${host}&${__url_time_range}\">Network</a></div>", "mode": "html"}, "title": "", "transparent": true, "type": "text"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 5, "w": 6, "x": 0, "y": 3}, "id": 1, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(probe_success{host=\"$host\",job=~\"${port:regex}\"} == 1) or on() vector(0)", "refId": "A"}], "title": "Ports Up", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 5, "w": 6, "x": 6, "y": 3}, "id": 2, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(probe_success{host=\"$host\",job=~\"${port:regex}\"} == 0) or on() vector(0)", "refId": "A"}], "title": "Ports Down", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "s"}}, "gridPos": {"h": 5, "w": 6, "x": 12, "y": 3}, "id": 3, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["mean"]}, "textMode": "value"}, "targets": [{"expr": "avg(probe_duration_seconds{host=\"$host\",job=~\"${port:regex}\"})", "refId": "A"}], "title": "Avg Probe Latency", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "unit": "s"}}, "gridPos": {"h": 5, "w": 6, "x": 18, "y": 3}, "id": 4, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["max"]}, "textMode": "value"}, "targets": [{"expr": "max(probe_duration_seconds{host=\"$host\",job=~\"${port:regex}\"})", "refId": "A"}], "title": "Max Probe Latency", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}, "1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}, "gridPos": {"h": 6, "w": 24, "x": 0, "y": 8}, "id": 5, "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": true}, "textMode": "value_and_name"}, "targets": [{"expr": "probe_success{host=\"$host\",job=~\"${port:regex}\"}", "legendFormat": "{{job}}", "refId": "A"}], "title": "Port Status", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "description": "Up/Down timeline for selected probes", "fieldConfig": {"defaults": {"custom": {"fillOpacity": 85, "lineWidth": 0}, "mappings": [{"options": {"0": {"color": "red", "index": 0, "text": "Down"}, "1": {"color": "green", "index": 1, "text": "Up"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}, "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14}, "id": 6, "options": {"alignValue": "left", "legend": {"displayMode": "list", "placement": "bottom"}, "mergeValues": true, "rowHeight": 0.9, "showValue": "never"}, "targets": [{"expr": "probe_success{host=\"$host\",job=~\"${port:regex}\"}", "legendFormat": "{{job}}", "refId": "A"}], "title": "Port Reachability Timeline", "type": "state-timeline"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "s"}}, "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22}, "id": 7, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "probe_duration_seconds{host=\"$host\",job=~\"${port:regex}\"}", "legendFormat": "{{job}}", "refId": "A"}], "title": "Probe Latency Over Time", "type": "timeseries"}
    ]
  },
  "folderUid": "monitoring",

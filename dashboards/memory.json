      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "lineWidth": 2}, "unit": "bytes"}}, "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8}, "id": 6, "options": {"legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "avg(node_memory_SwapTotal_bytes{host=\"$host\",job=\"integrations/unix\"})", "legendFormat": "Swap Total", "refId": "A"}, {"expr": "avg(node_memory_SwapTotal_bytes{host=\"$host\",job=\"integrations/unix\"}) - avg(node_memory_SwapFree_bytes{host=\"$host\",job=\"integrations/unix\"})", "legendFormat": "Swap Used", "refId": "B"}], "title": "Swap Usage", "type": "timeseries"},

      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"decimals": 1, "max": 100, "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}}, "gridPos": {"h": 5, "w": 6, "x": 0, "y": 3}, "id": 1, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "(1 - (avg(node_memory_MemAvailable_bytes{host=\"$host\",job=\"integrations/unix\"}) / avg(node_memory_MemTotal_bytes{host=\"$host\",job=\"integrations/unix\"}))) * 100", "refId": "A"}], "title": "Memory Used %", "type": "stat"},

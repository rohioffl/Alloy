        {"allValue": ".*", "current": {"text": "All", "value": "$__all"}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "includeAll": true, "label": "Account", "multi": false, "name": "account", "query": {"query": "label_values(node_uname_info{job=\"integrations/unix\",client=~\"$client\"}, account)", "refId": "A"}, "refresh": 2, "sort": 1, "type": "query"}
      ]

{
  "dashboard": {
    "uid": "alloy-fleet",
    "title": "Fleet Overview - All Servers",
    "tags": ["fleet", "overview", "alloy", "servers"],
    "refresh": "30s",
    "time": {"from": "now-5m", "to": "now"},
    "templating": {
      "list": [
        {"name": "client", "type": "query", "label": "Client", "datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "includeAll": true, "allValue": ".*", "multi": false, "current": {"text": "All", "value": "$__all"}, "refresh": 2, "sort": 1, "query": {"query": "label_values(monitor_node_info, client)", "refId": "client"}},
        {"name": "account", "type": "query", "label": "Account", "datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "includeAll": true, "allValue": ".*", "multi": false, "current": {"text": "All", "value": "$__all"}, "refresh": 2, "sort": 1, "query": {"query": "label_values(monitor_node_info{client=~\"$client\"}, account)", "refId": "account"}}
      ]
    },
    "panels": [
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}, "id": 1, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(monitor_node_info{client=~\"$client\",account=~\"$account\"}) or on() vector(0)", "refId": "A"}], "title": "Total Servers", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0}, "id": 2, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count((max by (host) (up{job=\"integrations/unix\"}) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}) == 1) or on() vector(0)", "refId": "A"}], "title": "Up", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0}, "id": 3, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count((max by (host) (up{job=\"integrations/unix\"}) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}) == 0) or on() vector(0)", "refId": "A"}], "title": "Down", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}, "id": 4, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(((100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}) > 90) or on() vector(0)", "refId": "A"}], "title": "Critical (CPU>90%)", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0}, "id": 5, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(((100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}) > 70 < 90) or on() vector(0)", "refId": "A"}], "title": "Warning (CPU>70%)", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0}, "id": 6, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(count by (client) (monitor_node_info{client=~\"$client\",account=~\"$account\"})) or on() vector(0)", "refId": "A"}], "title": "Clients", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "__PROM_DS_UID__"}, "description": "All servers with live health status (client/account from the central registry). Click a host to drill down.", "fieldConfig": {"defaults": {"custom": {"align": "left", "filterable": true}}, "overrides": [{"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "mappings", "value": [{"options": {"0": {"color": "red", "index": 0, "text": "\ud83d\udd34 DOWN"}, "1": {"color": "green", "index": 1, "text": "\ud83d\udfe2 UP"}}, "type": "value"}]}, {"id": "custom.cellOptions", "value": {"type": "color-text"}}, {"id": "custom.width", "value": 100}]}, {"matcher": {"id": "byName", "options": "CPU %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Memory %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Disk %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Load"}, "properties": [{"id": "decimals", "value": 2}]}, {"matcher": {"id": "byName", "options": "Uptime"}, "properties": [{"id": "unit", "value": "s"}]}, {"matcher": {"id": "byName", "options": "Host"}, "properties": [{"id": "links", "value": [{"title": "Drill down to $__value.raw", "url": "/d/alloy-drilldown/server-drill-down-alloy?var-host=${__value.raw}&var-client=All&var-account=All"}]}]}]}, "gridPos": {"h": 18, "w": 24, "x": 0, "y": 4}, "id": 10, "options": {"cellHeight": "md", "footer": {"show": false}, "showHeader": true, "sortBy": [{"desc": false, "displayName": "Status"}]}, "targets": [{"expr": "max by (host) (up{job=\"integrations/unix\"}) * on(host) group_left(client,account,name,ip) monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "Status"}, {"expr": "(100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "CPU"}, {"expr": "(max by (host) ((1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100)) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "Memory"}, {"expr": "(max by (host) (100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100))) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "Disk"}, {"expr": "(max by (host) (node_load1{job=\"integrations/unix\"})) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "Load"}, {"expr": "(time() - max by (host) (node_boot_time_seconds{job=\"integrations/unix\"})) * on(host) group_left() monitor_node_info{client=~\"$client\",account=~\"$account\"}", "format": "table", "instant": true, "refId": "Uptime"}], "title": "Server Status", "transformations": [{"id": "joinByField", "options": {"byField": "host", "mode": "outer"}}, {"id": "organize", "options": {"excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true, "__name__": true, "hostname": true, "instance": true, "job": true}, "indexByName": {"host": 0, "name": 1, "ip": 2, "client": 3, "account": 4, "Value #Status": 5, "Value #CPU": 6, "Value #Memory": 7, "Value #Disk": 8, "Value #Load": 9, "Value #Uptime": 10}, "renameByName": {"host": "Host", "name": "Display Name", "ip": "IP", "client": "Client", "account": "Account", "Value #Status": "Status", "Value #CPU": "CPU %", "Value #Memory": "Memory %", "Value #Disk": "Disk %", "Value #Load": "Load", "Value #Uptime": "Uptime"}}}], "type": "table"},
      {"type": "alertlist", "id": 20, "title": "Active Alerts", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22}, "options": {"alertInstanceLabelFilter": "", "dashboardAlerts": false, "groupMode": "default", "maxItems": 30, "sortOrder": 3, "stateFilter": {"firing": true, "pending": true, "error": true, "noData": false, "normal": false}, "viewMode": "list"}, "transparent": false}
    ]
  },
  "folderUid": "monitoring",
  "overwrite": true
}

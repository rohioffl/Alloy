    "panels": [
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}, "id": 1, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(max by (host) (node_uname_info{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}))", "refId": "A"}], "title": "Total Servers", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0}, "id": 2, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(max by (host) (up{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}) == 1) or on() vector(0)", "refId": "A"}], "title": "Up", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0}, "id": 3, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(max by (host) (up{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}) == 0) or on() vector(0)", "refId": "A"}], "title": "Down", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}, "id": 4, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count((100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}[5m])) * 100) > 90)) or on() vector(0)", "refId": "A"}], "title": "Critical (CPU>90%)", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "orange", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0}, "id": 5, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count((100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}[5m])) * 100) > 70 < 90)) or on() vector(0)", "refId": "A"}], "title": "Warning (CPU>70%)", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "fieldConfig": {"defaults": {"color": {"fixedColor": "purple", "mode": "fixed"}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0}, "id": 6, "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value"}, "targets": [{"expr": "count(count by (client) (node_uname_info{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"})) or on() vector(0)", "refId": "A"}], "title": "Clients", "type": "stat"},
      {"datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "description": "All servers with live health status. Click a host to drill down.", "fieldConfig": {"defaults": {"custom": {"align": "left", "filterable": true}}, "overrides": [{"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "mappings", "value": [{"options": {"0": {"color": "red", "index": 0, "text": "\ud83d\udd34 DOWN"}, "1": {"color": "green", "index": 1, "text": "\ud83d\udfe2 UP"}}, "type": "value"}]}, {"id": "custom.cellOptions", "value": {"type": "color-text"}}, {"id": "custom.width", "value": 110}]}, {"matcher": {"id": "byName", "options": "CPU %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Memory %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Disk %"}, "properties": [{"id": "unit", "value": "percent"}, {"id": "decimals", "value": 1}, {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "gauge"}}, {"id": "max", "value": 100}, {"id": "min", "value": 0}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}]}, {"matcher": {"id": "byName", "options": "Load"}, "properties": [{"id": "decimals", "value": 2}]}, {"matcher": {"id": "byName", "options": "Uptime"}, "properties": [{"id": "unit", "value": "s"}]}, {"matcher": {"id": "byName", "options": "Host"}, "properties": [{"id": "links", "value": [{"title": "Drill down to $__value.raw", "url": "/d/alloy-drilldown/server-drill-down-alloy?var-host=${__value.raw}&var-client=All&var-account=All"}]}]}]}, "gridPos": {"h": 18, "w": 24, "x": 0, "y": 4}, "id": 10, "options": {"cellHeight": "md", "footer": {"show": false}, "showHeader": true, "sortBy": [{"desc": false, "displayName": "Status"}]}, "targets": [{"expr": "max by (host, client, account) (up{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"})", "format": "table", "instant": true, "refId": "Status"}, {"expr": "100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\",job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}[5m])) * 100)", "format": "table", "instant": true, "refId": "CPU"}, {"expr": "(1 - (max by (host) (node_memory_MemAvailable_bytes{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}) / max by (host) (node_memory_MemTotal_bytes{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"}))) * 100", "format": "table", "instant": true, "refId": "Memory"}, {"expr": "100 - ((max by (host) (node_filesystem_avail_bytes{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\",mountpoint=\"/\",fstype!=\"tmpfs\"}) / max by (host) (node_filesystem_size_bytes{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\",mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100)", "format": "table", "instant": true, "refId": "Disk"}, {"expr": "max by (host) (node_load1{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"})", "format": "table", "instant": true, "refId": "Load"}, {"expr": "time() - max by (host) (node_boot_time_seconds{job=\"integrations/unix\",client=~\"$client\",account=~\"$account\"})", "format": "table", "instant": true, "refId": "Uptime"}], "title": "Server Status", "transformations": [{"id": "joinByField", "options": {"byField": "host", "mode": "outer"}}, {"id": "organize", "options": {"excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true}, "indexByName": {"host": 0, "client": 1, "account": 2, "Value #Status": 3, "Value #CPU": 4, "Value #Memory": 5, "Value #Disk": 6, "Value #Load": 7, "Value #Uptime": 8}, "renameByName": {"host": "Host", "client": "Client", "account": "Account", "Value #Status": "Status", "Value #CPU": "CPU %", "Value #Memory": "Memory %", "Value #Disk": "Disk %", "Value #Load": "Load", "Value #Uptime": "Uptime"}}}], "type": "table"},

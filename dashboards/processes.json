{
  "uid": "alloy-dd-proc",
  "title": "Server Drill-Down \u00b7 Processes (Alloy)",
  "tags": [
    "processes",
    "drilldown",
    "server",
    "alloy"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "P79940EC37D9FBFF2"
        },
        "includeAll": true,
        "label": "Client",
        "name": "client",
        "query": {
          "infinityQuery": {
            "refId": "variable",
            "source": "url",
            "type": "json",
            "url": "/api/v1/variables/clients"
          },
          "queryType": "infinity",
          "type": "infinity"
        },
        "refresh": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "P79940EC37D9FBFF2"
        },
        "includeAll": true,
        "label": "Account",
        "name": "account",
        "query": {
          "infinityQuery": {
            "refId": "variable",
            "source": "url",
            "type": "json",
            "url": "/api/v1/variables/accounts?client=${client}"
          },
          "queryType": "infinity",
          "type": "infinity"
        },
        "refresh": 1,
        "type": "query"
      },
      {
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "P79940EC37D9FBFF2"
        },
        "includeAll": false,
        "label": "Host",
        "name": "host",
        "query": {
          "infinityQuery": {
            "refId": "variable",
            "source": "url",
            "type": "json",
            "url": "/api/v1/variables/hosts?client=${client}&account=${account}"
          },
          "queryType": "infinity",
          "type": "infinity"
        },
        "refresh": 1,
        "sort": 0,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "definition": "label_values(namedprocess_namegroup_cpu_seconds_total{host=\"$host\"}, groupname)",
        "includeAll": true,
        "label": "Process",
        "multi": true,
        "name": "process",
        "query": "label_values(namedprocess_namegroup_cpu_seconds_total{host=\"$host\"}, groupname)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "content": "<div style=\"display:flex;align-items:flex-end;gap:24px;padding:12px 18px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-family:Inter,system-ui,sans-serif;font-size:14px;\"><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-drilldown/server-drill-down-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">Summary</a><a style=\"color:#fff;text-decoration:none;padding:6px 2px 10px;border-bottom:2px solid #f59e0b;font-weight:600;\">Processes</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-port/server-drill-down-ports-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">Ports</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-cpu/server-drill-down-cpu-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">CPU</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-mem/server-drill-down-memory-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">Memory</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-disk/server-drill-down-disks-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">Disks</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 10px;\" href=\"/d/alloy-dd-net/server-drill-down-network-alloy?var-client=${client}&var-account=${account}&var-host=${host}&${__url_time_range}\">Network</a></div>",
        "mode": "html"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "topk(5, sum by (groupname) (rate(namedprocess_namegroup_cpu_seconds_total{host=\"$host\",groupname=~\"${process:regex}\"}[5m])) * 100)",
          "legendFormat": "{{groupname}}",
          "refId": "A"
        }
      ],
      "title": "Top Processes \u2014 CPU %",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {

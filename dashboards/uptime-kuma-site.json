{
  "uid": "uptime-kuma-site",
  "title": "Site Monitor",
  "tags": [
    "site",
    "drilldown",
    "monitoring"
  ],
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "monitor",
        "type": "query",
        "label": "Monitor",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "definition": "label_values(monitor_kuma_site_info, monitor_name)",
        "query": "label_values(monitor_kuma_site_info, monitor_name)",
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "customer",
        "type": "query",
        "label": "Customer",
        "hide": 2,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "definition": "label_values(monitor_kuma_site_info{monitor_name=\"$monitor\"}, client)",
        "query": "label_values(monitor_kuma_site_info{monitor_name=\"$monitor\"}, client)",
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "hide": 2,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "definition": "label_values(monitor_kuma_site_info{monitor_name=\"$monitor\"}, account)",
        "query": "label_values(monitor_kuma_site_info{monitor_name=\"$monitor\"}, account)",
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "content": "<div style=\"display:flex;align-items:flex-end;gap:24px;padding:8px 18px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-family:Inter,system-ui,sans-serif;font-size:14px;\"><a style=\"color:#fff;text-decoration:none;padding:6px 2px 8px;border-bottom:2px solid #f59e0b;font-weight:600;\">Site summary</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/uptime-kuma-source/uptime-kuma?var-monitor=${monitor}&${__url_time_range}\">Site source</a><a style=\"color:rgba(255,255,255,0.65);text-decoration:none;padding:6px 2px 8px;\" href=\"/d/alloy-fleet/fleet-overview-all-servers?var-customer=${customer}&var-environment=${environment}&${__url_time_range}\">Fleet overview</a></div>",
        "mode": "html"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 2
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "min(monitor_status{job=\"uptime-kuma\",monitor_name=\"$monitor\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Current Status",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 2
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "avg_over_time((min(monitor_status{job=\"uptime-kuma\",monitor_name=\"$monitor\"}))[$__range:]) * 100",
          "refId": "A"
        }
      ],
      "title": "Availability",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "decimals": 0,
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 2
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "avg(monitor_response_time{job=\"uptime-kuma\",monitor_name=\"$monitor\"})",
          "refId": "A"
        }
      ],
      "title": "Response Time",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 2
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertname=\"Site Monitor Down\",monitor_name=\"$monitor\",alertstate=~\"pending|firing\"}) or on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "Open Alerts",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 8,
      "options": {
        "content": "<iframe src=\"https://zentra.ankercloud.com/monitor-api/silence?alertname=Site%20Monitor%20Down&monitor_name=${monitor}\" style=\"width:100%;height:100%;border:none;border-radius:8px;\"></iframe>",
        "mode": "html"
      },
      "title": "Silence",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "DOWN",
                        "color": "red"
                      },
                      "1": {
                        "text": "UP",
                        "color": "green"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Response"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "monitor_kuma_site_info{monitor_name=\"$monitor\"}",
          "format": "table",
          "instant": true,
          "refId": "Info"
        },
        {
          "expr": "min by (monitor_name) (monitor_status{job=\"uptime-kuma\",monitor_name=\"$monitor\"})",
          "format": "table",
          "instant": true,
          "refId": "Status"
        },
        {
          "expr": "avg by (monitor_name) (monitor_response_time{job=\"uptime-kuma\",monitor_name=\"$monitor\"})",
          "format": "table",
          "instant": true,
          "refId": "Response"
        }
      ],
      "title": "Site Details",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "monitor_name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "site": true
            },
            "indexByName": {
              "monitor_name": 0,
              "name": 1,
              "customer": 2,
              "environment": 3,
              "monitor_type": 4,
              "target": 5,
              "Value #Status": 6,
              "Value #Response": 7
            },
            "renameByName": {
              "monitor_name": "Monitor",
              "name": "Display Name",
              "customer": "Customer",
              "environment": "Account",
              "monitor_type": "Type",
              "target": "Target",
              "Value #Status": "Status",
              "Value #Response": "Response"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "avg by (monitor_name) (monitor_response_time{job=\"uptime-kuma\",monitor_name=\"$monitor\"})",
          "legendFormat": "{{monitor_name}}",
          "refId": "A"
        }
      ],
      "title": "Response Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Down",
                  "color": "red"
                },
                "1": {
                  "text": "Up",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 7,
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "min by (monitor_name) (monitor_status{job=\"uptime-kuma\",monitor_name=\"$monitor\"})",
          "legendFormat": "{{monitor_name}}",
          "refId": "A"
        }
      ],
      "title": "Status Timeline",
      "type": "state-timeline"
    }
  ],
  "overwrite": true
}